# ── Telegram ──────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here       # Push alert target (group/channel)

# ── AI (dual model) ──────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_key_here
CLAUDE_MODEL_DEEP=claude-opus-4-6
CLAUDE_MODEL_FAST=claude-sonnet-4-20250514

# ── Elfa AI ──────────────────────────────────────────
ELFA_API_KEY=your_elfa_key_here

# ── CoinGlass ────────────────────────────────────────
COINGLASS_API_KEY=your_coinglass_key_here

# ── CoinGecko ────────────────────────────────────────
COINGECKO_API_KEY=your_coingecko_key_here

# ── TradingView Webhooks ─────────────────────────────
WEBHOOK_HOST=0.0.0.0
WEBHOOK_PORT=8443
WEBHOOK_SECRET=change_me_to_a_strong_secret
WEBHOOK_URL=                              # Public URL for TradingView (optional)

# ── Binance ──────────────────────────────────────────
BINANCE_BASE_URL=https://api.binance.com

